# .env.example — CTR Rosales QC reconciliation backend
#
# Copy to .env and fill in your secrets. This file is safe to commit.
# Never commit .env itself (it is listed in .gitignore).
#
# Priority order (highest wins):
#   1. Environment variables set in the shell
#   2. This .env file (loaded by pydantic-settings env_file)
#   3. config.yaml values
#   4. Coded defaults

# Vision LLM providers — set the key for whichever provider you use
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Provider selection (anthropic | openai | ollama)
VISION_PROVIDER=anthropic

# Hard cap on vision LLM calls per run (per-block billing: one call per guia block)
MAX_VISION_CALLS=600
