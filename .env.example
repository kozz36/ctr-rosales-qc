# =============================================================================
# .env.example — ctr-rosales-qc (repo root)
#
# Copy to .env and edit:  cp .env.example .env
# .env is gitignored — NEVER commit it (it may carry API keys).
#
# Two consumers:
#   1. Docker Compose interpolation — `${VAR}` in docker-compose.yml is filled
#      from THIS root .env. Only OLLAMA_MODEL + OLLAMA_BASE_URL are interpolated.
#   2. Backend app (pydantic-settings AppConfig) — loads .env from its CWD.
#      App settings use prefix RECONCILIATION__ and nested delimiter __
#      (e.g. RECONCILIATION__VISION__PROVIDER). API keys are the ONLY bare names
#      that bind (injected from os.environ by VisionConfig).
#
# Priority (highest wins): shell env > .env > config.yaml > coded defaults.
# In docker-compose.yml the RECONCILIATION__* values are set LITERALLY in the
# service environment: block — for container runs edit them there. The keys below
# apply when running the backend process directly / as a reference.
# =============================================================================

# --- Docker Compose interpolation (read from THIS file by `docker compose`) ---
OLLAMA_MODEL=qwen3.5:397b-cloud
OLLAMA_BASE_URL=http://localhost:11434/v1

# --- Vision API keys (bare names — injected by VisionConfig validator) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Vision (RECONCILIATION__VISION__*) ---
# provider: anthropic | openai | ollama
RECONCILIATION__VISION__PROVIDER=ollama
RECONCILIATION__VISION__MAX_VISION_CALLS=500
RECONCILIATION__VISION__MAX_TOKENS=640
RECONCILIATION__VISION__TIMEOUT_S=30.0
RECONCILIATION__VISION__DEADLINE_S=20.0
# /no_think — DEFAULT ON: improves OCR capture + removes ~12s/call qwen3.5 latency
RECONCILIATION__VISION__DISABLE_THINKING=true
RECONCILIATION__VISION__FALLBACK_DPI=300
RECONCILIATION__VISION__ANTHROPIC__MODEL=claude-3-5-sonnet-20241022
RECONCILIATION__VISION__OPENAI__MODEL=gpt-4o
RECONCILIATION__VISION__OLLAMA__MODEL=qwen3.5:397b-cloud
RECONCILIATION__VISION__OLLAMA__BASE_URL=http://localhost:11434/v1
# Guia stamp crop (fractional 0-1). All four = 0.0 disables cropping.
RECONCILIATION__VISION__STAMP_CROP__X0=0.55
RECONCILIATION__VISION__STAMP_CROP__Y0=0.05
RECONCILIATION__VISION__STAMP_CROP__X1=1.00
RECONCILIATION__VISION__STAMP_CROP__Y1=0.45
# Protocolo Fecha crop (R10.9 calibration)
RECONCILIATION__VISION__PROTOCOLO_CROP__X0=0.60
RECONCILIATION__VISION__PROTOCOLO_CROP__Y0=0.14
RECONCILIATION__VISION__PROTOCOLO_CROP__X1=1.00
RECONCILIATION__VISION__PROTOCOLO_CROP__Y1=0.22

# --- OCR (RECONCILIATION__OCR__*) ---
# false on machines where paddle crashes on load (oneDNN/PIR); SUNAT supplies qty
RECONCILIATION__OCR__ENABLED=true

# --- SUNAT fetch (RECONCILIATION__SUNAT__*) — OFF: only network egress, breaks air-gap ---
RECONCILIATION__SUNAT__ENABLED=false
RECONCILIATION__SUNAT__TIMEOUT_S=10.0
RECONCILIATION__SUNAT__CACHE=true
# RECONCILIATION__SUNAT__CACHE_DIR=/data/sunat-cache

# --- Material inference (RECONCILIATION__INFERENCE__*) — OFF, local Ollama only ---
RECONCILIATION__INFERENCE__ENABLED=false
RECONCILIATION__INFERENCE__PROVIDER=ollama
RECONCILIATION__INFERENCE__MODEL=qwen3.5:9b
RECONCILIATION__INFERENCE__BASE_URL=http://localhost:11434/v1
RECONCILIATION__INFERENCE__TEMPERATURE=0.0
RECONCILIATION__INFERENCE__TIMEOUT_S=30.0

# --- Output ---
RECONCILIATION__OUTPUT_DIR=runs

# --- LOCKED (do NOT override without a spec amendment) ---
#   RECONCILIATION__CONFIDENCE__THRESHOLD=0.85   # frozen — ValueError if changed (EXT-002)
#   RECONCILIATION__DESKEW__SCOPE=guia_only      # locked (EXT-003)
